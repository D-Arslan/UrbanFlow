# Copie ce fichier en `.env` et remplis les valeurs.
# Le `.env` n'est JAMAIS versionné (voir .gitignore).

# --- PostgreSQL ---
POSTGRES_USER=urbanflow
POSTGRES_PASSWORD=change-me
POSTGRES_DB=urbanflow
# Où joindre la base. Depuis l'HÔTE (API/dashboard lancés hors Docker) : localhost.
# POSTGRES_PORT sert DOUBLE : port publié par docker-compose ET port de connexion de l'API.
# Mettre 5433 si un PostgreSQL natif occupe déjà 5432. Depuis un conteneur : "postgres:5432".
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- MinIO (stockage objet S3, historique Parquet) ---
# ROOT_USER  = access key S3 ; ROOT_PASSWORD = secret key S3 (min. 8 caractères).
MINIO_ROOT_USER=urbanflow
MINIO_ROOT_PASSWORD=change-me-too
